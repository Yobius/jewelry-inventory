// Prisma schema for the jewelry inventory system.
// JSON columns are typed via @jewelry/types.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  SELLER
  CASHIER
  AUDITOR
}

enum Material {
  GOLD
  SILVER
  PLATINUM
  OTHER
}

enum TransactionType {
  IN
  OUT
  MOVE
  ADJUSTMENT
}

enum PrintJobStatus {
  QUEUED
  PRINTED
  CANCELLED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String
  role         UserRole      @default(SELLER)
  location     Json?
  items        Item[]        @relation("CreatedBy")
  transactions Transaction[]
  auditLogs    AuditLog[]
  imports      Import[]
  printJobs    PrintJob[]
  payments     Payment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([email])
  @@index([role])
}

model Manufacturer {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique // короткий код для префіксу SKU
  country   String?
  notes     String?
  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Supplier {
  id              String          @id @default(cuid())
  name            String          @unique
  code            String?         @unique
  contactEmail    String?
  contactPhone    String?
  notes           String?
  items           Item[]
  importMappings  ImportMapping[]
  imports         Import[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([name])
}

model Stone {
  id        String     @id @default(cuid())
  name      String     @unique // напр. "Діамант", "Фіаніт", "Сапфір"
  category  String? // дорогоцінний / напівдорогоцінний / синтетичний
  items     ItemStone[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([name])
}

// Join-таблиця: один виріб може мати кілька різних каменів
model ItemStone {
  id       String @id @default(cuid())
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  stoneId  String
  stone    Stone  @relation(fields: [stoneId], references: [id])
  count    Int    @default(1) // скільки каменів цього типу
  weight   Decimal? @db.Decimal(10, 3) // карат/г
  notes    String?

  @@unique([itemId, stoneId])
  @@index([itemId])
  @@index([stoneId])
}

model Item {
  id             String         @id @default(cuid())
  sku            String         @unique
  name           String
  specs          Json
  material       Material
  carat          Int?
  weight         Decimal        @db.Decimal(10, 2)
  pricing        Json
  identification Json
  manufacturerId String?
  manufacturer   Manufacturer?  @relation(fields: [manufacturerId], references: [id])
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  stones         ItemStone[]
  createdBy      String
  createdByUser  User           @relation("CreatedBy", fields: [createdBy], references: [id])
  inventory      Inventory?
  transactions   Transaction[]
  history        ItemHistory[]
  printJobs      PrintJob[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([sku])
  @@index([name])
  @@index([manufacturerId])
  @@index([supplierId])
  @@index([material, weight])
}

model Inventory {
  id         String   @id @default(cuid())
  itemId     String   @unique
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantities Json
  lastSync   DateTime @updatedAt

  @@index([itemId])
}

model Transaction {
  id        String          @id @default(cuid())
  itemId    String
  item      Item            @relation(fields: [itemId], references: [id])
  movement  Json
  quantity  Int
  type      TransactionType
  reason    String?
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
}

model ItemHistory {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  changes   Json
  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entityId  String
  before    Json?
  after     Json?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Налаштування мапінгу Excel-колонок для конкретного постачальника
model ImportMapping {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String // напр. "Накладна Златосвіт 2026 Q1"
  // Мапінг: { sku: "Артикул", name: "Назва", weight: "Вага", ... }
  mapping    Json
  // Опц. правила трансформації: { material: { "au585": "GOLD", "ag925": "SILVER" } }
  transforms Json?
  imports    Import[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, name])
  @@index([supplierId])
}

// Журнал імпортів — для аудиту та rollback
model Import {
  id           String         @id @default(cuid())
  supplierId   String?
  supplier     Supplier?      @relation(fields: [supplierId], references: [id])
  mappingId    String?
  mapping      ImportMapping? @relation(fields: [mappingId], references: [id])
  userId       String
  user         User           @relation(fields: [userId], references: [id])
  filename     String
  rowsTotal    Int
  rowsCreated  Int            @default(0)
  rowsUpdated  Int            @default(0)
  rowsSkipped  Int            @default(0)
  errors       Json? // список помилок по рядках
  status       String         @default("pending") // pending/completed/failed
  createdAt    DateTime       @default(now())
  completedAt  DateTime?

  @@index([supplierId])
  @@index([userId])
  @@index([createdAt])
}

// Черга друку бірок
model PrintJob {
  id         String         @id @default(cuid())
  itemId     String
  item       Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  copies     Int            @default(1)
  status     PrintJobStatus @default(QUEUED)
  batchId    String? // згрупувати кілька бірок в один A4-друк
  printedAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([itemId])
  @@index([status])
  @@index([batchId])
  @@index([createdAt])
}

// Платіж через POS (LiqPay / готівка / карта-без-терміналу)
enum PaymentMethod {
  CASH
  CARD
  TERMINAL // LiqPay / Privat terminal
}

enum PaymentStatus {
  PENDING // очікує оплати на терміналі
  SUCCESS // оплачено
  FAILED // відхилено
  CANCELLED // скасовано касиром
  EXPIRED // таймаут
}

model Payment {
  id           String        @id @default(cuid())
  // Our internal POS receipt identifier — also passed to LiqPay as order_id.
  receiptId    String        @unique
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  // UAH; stored as string decimal to match our pricing JSON format.
  amount       Decimal       @db.Decimal(12, 2)
  currency     String        @default("UAH")
  discountPct  Int           @default(0)
  // Snapshot of receipt lines for audit (itemId/sku/qty/unitPrice)
  items        Json
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  // LiqPay-specific data (provider orderId, payment_id, raw callback, etc.)
  providerRef  String?
  providerData Json?
  paidAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([receiptId])
  @@index([status])
  @@index([userId])
  @@index([createdAt])
}
